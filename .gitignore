# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Caches and logs
.pytest_cache/
.ruff_cache/
.mypy_cache/
.ipynb_checkpoints/
*.log

# Environments / Virtual environments
ml-env/
.venv/
venv/
env/
ENV/

# OS-specific files
.DS_Store
Thumbs.db

# IDEs and editors
.vscode/
.idea/

# Distribution / packaging
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
src/*.egg-info/

# Local configuration / secrets
.env
.env.local
.env.*.local

# MLOps - Data and Models (do not track datasets or model weights)
data/raw/*
!data/raw/.gitkeep
data/processed/*
!data/processed/.gitkeep

# Ignore trained models
models/*
!models/.gitkeep
